<%= form_with(model: client) do |form| %>
  <%= render "shared/error_messages", resource: client %>

  <div>
    <%= form.label :name %><br/>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :phone_number %><br/>
    <%= form.text_field :phone_number %>
  </div>

  <div>
    <%= form.label :email %><br/>
    <%= form.email_field :email %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
